# Copy this file to `.env` and fill in the two values from your Supabase
# project: Dashboard -> Project Settings -> API.
#
# Use the SAME values in every app you build — one Supabase project ("PWAs")
# backs them all, and each app's data is kept separate by its name. Both keys
# are *publishable* client keys; your data is protected by row-level security
# (see supabase/schema.sql), not by keeping these secret. `.env` stays out of git.
#
# Leave these unset to run the app local-only (no sign-in, no sync).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
